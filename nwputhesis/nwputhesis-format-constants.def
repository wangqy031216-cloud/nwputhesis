\cs_new:Npn \nwpuCoverInfoRowHeight { 1cm }                 % 封皮专业/导师等信息表单元格高度
\cs_new:Npn \nwpuCoverBackgroundInnerSep { 0pt }            % 彩色封面/封底背景图节点内边距
\cs_new:Npn \nwpuCoverAfterDetailSkip { 265pt }         % 封皮右上角信息表到题目表距离
\cs_new:Npn \nwpuCoverAfterTitleSkip { 30pt }           % 封皮题目表到作者表距离
\cs_new:Npn \nwpuCoverAfterAuthorSkip { 42pt }            % 封皮作者表到专业/导师信息表距离


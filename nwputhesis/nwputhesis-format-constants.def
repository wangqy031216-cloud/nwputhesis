\cs_new:Npn \nwpuCoverTitleRowHeight { 1.45cm }             % 封皮题目表单元格高度
\cs_new:Npn \nwpuCoverAuthorLabelWidth { 1.56cm }           % 封皮作者表标签列宽
\cs_new:Npn \nwpuCoverAuthorValueWidth { 3.72cm }           % 封皮作者表内容列宽
\cs_new:Npn \nwpuCoverAuthorRowHeight { 1.28cm }            % 封皮作者表单元格高度

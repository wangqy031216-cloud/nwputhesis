\cs_new:Npn \nwpuEngInnerAfterAdvisorSkip { 96pt }          % 英文内封导师信息后距
\cs_new:Npn \nwpuEngInnerBeforeDegreeSkip { 24pt }          % 英文内封学位说明前距
\cs_new:Npn \nwpuEngInnerAfterDegreeSkip { 88pt }           % 英文内封学位说明后距


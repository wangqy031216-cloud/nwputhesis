%% This file is part of nwputhesis.
%% It is loaded internally by nwputhesis.cls.
%%
%% 格式常量
%% 集中定义所有与学校格式规范直接对应的参数。
%% 当学校发布新规范时，通常只需修改本文件。
%%=========================================================================
\ExplSyntaxOn

%%=== 字号基础量 =========================================================
%% Point 只表示字号本身；LineHeight 表示该字号在模板中的默认基线距。
\cs_new:Npn \nwpuFontPointChuhao { 42pt }                   % 初号字号
\cs_new:Npn \nwpuFontPointYihao { 26pt }                    % 一号字号
\cs_new:Npn \nwpuFontPointErhao { 22pt }                    % 二号字号
\cs_new:Npn \nwpuFontPointXiaoer { 18pt }                   % 小二字号
\cs_new:Npn \nwpuFontPointSanhao { 16pt }                   % 三号字号
\cs_new:Npn \nwpuFontPointXiaosan { 15pt }                  % 小三字号
\cs_new:Npn \nwpuFontPointSihao { 14pt }                    % 四号字号
\cs_new:Npn \nwpuFontPointXiaosi { 12pt }                   % 小四字号
\cs_new:Npn \nwpuFontPointWuhao { 10.5pt }                  % 五号字号
\cs_new:Npn \nwpuFontPointXiaowu { 9pt }                    % 小五字号

\cs_new:Npn \nwpuLineHeightChuhao { 63pt }                  % 初号默认基线距
\cs_new:Npn \nwpuLineHeightYihao { 36pt }                   % 一号默认基线距
\cs_new:Npn \nwpuLineHeightErhao { 28pt }                   % 二号默认基线距
\cs_new:Npn \nwpuLineHeightXiaoer { 18pt }                  % 小二默认基线距
\cs_new:Npn \nwpuLineHeightSanhao { 24pt }                  % 三号默认基线距
\cs_new:Npn \nwpuLineHeightXiaosan { 22pt }                 % 小三默认基线距
\cs_new:Npn \nwpuLineHeightSihao { 21pt }                   % 四号默认基线距
\cs_new:Npn \nwpuLineHeightXiaosi { 14.4pt }                % 小四默认基线距
\cs_new:Npn \nwpuBachelorLineHeight { 20pt }                % 本科正文体系统一基线距
\cs_new:Npn \nwpuGraduateLineHeight { 20pt }                % 研究生正文体系统一基线距
\nwpu_if_bachelor:TF
  { \cs_new:Npn \nwpuLineHeightBody { \nwpuBachelorLineHeight } } % 本科正文小四基线距
  { \cs_new:Npn \nwpuLineHeightBody { \nwpuGraduateLineHeight } } % 研究生正文小四基线距
\cs_new:Npn \nwpuLineHeightWuhao { 10.5pt }                 % 五号默认基线距
\cs_new:Npn \nwpuLineHeightXiaowu { 9pt }                   % 小五默认基线距

%%=== 纯字号宏 ===========================================================
%% 仅切换字号，基线距取同字号；语义化版式应优先使用下一节的角色宏。
\cs_new_protected:Npn \nwpuFontSizeChuhao { \fontsize{\nwpuFontPointChuhao}{\nwpuFontPointChuhao}\selectfont } % 初号纯字号
\cs_new_protected:Npn \nwpuFontSizeYihao { \fontsize{\nwpuFontPointYihao}{\nwpuFontPointYihao}\selectfont }    % 一号纯字号
\cs_new_protected:Npn \nwpuFontSizeErhao { \fontsize{\nwpuFontPointErhao}{\nwpuFontPointErhao}\selectfont }    % 二号纯字号
\cs_new_protected:Npn \nwpuFontSizeXiaoer { \fontsize{\nwpuFontPointXiaoer}{\nwpuFontPointXiaoer}\selectfont } % 小二纯字号
\cs_new_protected:Npn \nwpuFontSizeSanhao { \fontsize{\nwpuFontPointSanhao}{\nwpuFontPointSanhao}\selectfont } % 三号纯字号
\cs_new_protected:Npn \nwpuFontSizeXiaosan { \fontsize{\nwpuFontPointXiaosan}{\nwpuFontPointXiaosan}\selectfont } % 小三纯字号
\cs_new_protected:Npn \nwpuFontSizeSihao { \fontsize{\nwpuFontPointSihao}{\nwpuFontPointSihao}\selectfont }    % 四号纯字号
\cs_new_protected:Npn \nwpuFontSizeXiaosi { \fontsize{\nwpuFontPointXiaosi}{\nwpuFontPointXiaosi}\selectfont } % 小四纯字号
\cs_new_protected:Npn \nwpuFontSizeWuhao { \fontsize{\nwpuFontPointWuhao}{\nwpuFontPointWuhao}\selectfont }    % 五号纯字号
\cs_new_protected:Npn \nwpuFontSizeXiaowu { \fontsize{\nwpuFontPointXiaowu}{\nwpuFontPointXiaowu}\selectfont } % 小五纯字号

%%=== 语义化字体角色 =====================================================
%% 将字体族、字号、字重映射到格式规范中的角色。学校改格式要求时，修改这里的映射。
%%-------------------------------------------------------------------------
%% 章节标题（完整字体：族 + 字号 + 行距）
\nwpu_if_bachelor:TF
  {
    \cs_new_protected:Npn \nwpuChapterFont { \sffamily\fHei\fontsize{\nwpuFontPointSanhao}{\nwpuBachelorLineHeight}\selectfont }
    \cs_new_protected:Npn \nwpuSectionFont { \sffamily\fHei\fontsize{\nwpuFontPointSihao}{\nwpuBachelorLineHeight}\selectfont }
    \cs_new_protected:Npn \nwpuSubsectionFont { \sffamily\fHei\fontsize{\nwpuFontPointXiaosi}{\nwpuBachelorLineHeight}\selectfont }
    \cs_new_protected:Npn \nwpuSubsubsectionFont { \sffamily\fHei\fontsize{\nwpuFontPointXiaosi}{\nwpuBachelorLineHeight}\selectfont }
  }
  {
    \cs_new_protected:Npn \nwpuChapterFont { \sffamily\fHei\fontsize{\nwpuFontPointSanhao}{\nwpuGraduateLineHeight}\selectfont }
    \cs_new_protected:Npn \nwpuSectionFont { \sffamily\fHei\fontsize{\nwpuFontPointSihao}{\nwpuGraduateLineHeight}\selectfont }
    \cs_new_protected:Npn \nwpuSubsectionFont { \sffamily\fHei\fontsize{\nwpuFontPointXiaosi}{\nwpuGraduateLineHeight}\selectfont }
    \cs_new_protected:Npn \nwpuSubsubsectionFont { \sffamily\fHei\fontsize{\nwpuFontPointXiaosi}{\nwpuGraduateLineHeight}\selectfont }
  }

%% 目录
\cs_new_protected:Npn \nwpuTOCFont { \fSong }

%% 关键词标签
\cs_new_protected:Npn \nwpuKeywordFont { \fHei }

%% 图表标题
\nwpu_if_bachelor:TF
  { \cs_new_protected:Npn \nwpuCaptionSize { \fontsize{\nwpuFontPointWuhao}{\nwpuBachelorLineHeight}\selectfont } } % 本科图表标题字号
  { \cs_new_protected:Npn \nwpuCaptionSize { \fontsize{\nwpuFontPointWuhao}{\nwpuGraduateLineHeight}\selectfont } } % 研究生图表标题字号
\nwpu_if_bachelor:TF
  {
    \cs_new_protected:Npn \nwpuTableCaptionFont { \nwpuCaptionSize\bfseries }
    \cs_new_protected:Npn \nwpuFigureCaptionFont { \nwpuCaptionSize\fSong }
  }
  {
    \cs_new_protected:Npn \nwpuTableCaptionFont { \nwpuCaptionSize }
    \cs_new_protected:Npn \nwpuFigureCaptionFont { \nwpuCaptionSize }
  }

%% 页眉页脚
\nwpu_if_bachelor:TF
  { \cs_new_protected:Npn \nwpuHeaderFooterSize { \fontsize{\nwpuFontPointXiaowu}{\nwpuBachelorLineHeight}\selectfont } } % 本科页眉页脚字号
  { \cs_new_protected:Npn \nwpuHeaderFooterSize { \fontsize{\nwpuFontPointXiaowu}{\nwpuGraduateLineHeight}\selectfont } } % 研究生页眉页脚字号

%% 目录条目
\nwpu_if_bachelor:TF
  { \cs_new:Npn \nwpuTOCLineHeight { \nwpuBachelorLineHeight } } % 本科目录条目基线距
  { \cs_new:Npn \nwpuTOCLineHeight { \nwpuGraduateLineHeight } } % 研究生目录条目基线距
\cs_new_protected:Npn \nwpuTOCEntryFont { \nwpuTOCFont\fontsize{\nwpuFontPointXiaosi}{\nwpuTOCLineHeight}\selectfont }

%%=== 正文格式 ===========================================================
\cs_new:Npn \nwpuBodyLineSpread { 1.0 }                     % 正文基础行距倍率
\cs_new_protected:Npn \nwpuBodyFont { \linespread{\nwpuBodyLineSpread}\fontsize{\nwpuFontPointXiaosi}{\nwpuLineHeightBody}\selectfont } % 正文字体字号组合

%%=== 页面边距 ===========================================================
\nwpu_if_bachelor:TF {
  \cs_new:Npn \nwpuMarginLeft     { 3.18cm }                % 本科左页边距
  \cs_new:Npn \nwpuMarginRight    { 3.18cm }                % 本科右页边距
  \cs_new:Npn \nwpuMarginTop      { 2.54cm }                % 本科上页边距
  \cs_new:Npn \nwpuMarginBottom   { 2.54cm }                % 本科下页边距
  \cs_new:Npn \nwpuHeadHeight     { 0.93cm }                % 本科页眉高度
  \cs_new:Npn \nwpuTopMargin      { -35pt }                    % 本科页眉到页面顶部距离
  \cs_new:Npn \nwpuHeadSep        { 0.4cm }                 % 本科页眉到正文距离
  \cs_new:Npn \nwpuFootSkip       { 0.79cm }                % 本科正文到底部页脚基线距离
  \cs_new:Npn \nwpuBottomMargin   { 0pt }                    % 本科页脚基线到页面底部距离
} {
  \cs_new:Npn \nwpuMarginLeft     { 2.5cm }                 % 研究生左页边距
  \cs_new:Npn \nwpuMarginRight    { 2.5cm }                 % 研究生右页边距
  \cs_new:Npn \nwpuMarginTop      { 2.54cm }                % 研究生上页边距
  \cs_new:Npn \nwpuMarginBottom   { 2.54cm }                % 研究生下页边距
  \cs_new:Npn \nwpuHeadHeight     { 1.0cm }                 % 研究生页眉高度
  \cs_new:Npn \nwpuTopMargin      { -45pt }                    % 研究生页眉到页面顶部距离
  \cs_new:Npn \nwpuHeadSep        { 0.7cm }                % 研究生页眉到正文距离
  \cs_new:Npn \nwpuFootSkip       { 0.79cm }                % 研究生正文到底部页脚基线距离
  \cs_new:Npn \nwpuBottomMargin   { 0pt }                    % 研究生页脚基线到页面底部距离
}

%%=== 段落格式 ===========================================================
\cs_new:Npn \nwpuParIndent { 24pt }                         % 段首缩进
\cs_new:Npn \nwpuParSkip { 0pt }                            % 段间距

%%=== 章节标题间距 =======================================================
%% \titlespacing{<cmd>}{<left>}{<before>}{<after>}[<right>]
\nwpu_if_bachelor:TF {
  \cs_new:Npn \nwpuChapterBeforeSkip   { 5pt }              % 本科章标题前距
  \cs_new:Npn \nwpuChapterAfterSkip    { 17pt }             % 本科章标题后距
  \cs_new:Npn \nwpuSectionBeforeSkip   { 2pt }              % 本科节标题前距
  \cs_new:Npn \nwpuSectionAfterSkip    { 2pt }              % 本科节标题后距
  \cs_new:Npn \nwpuSubsecBeforeSkip    { 3pt }              % 本科小节标题前距
  \cs_new:Npn \nwpuSubsecAfterSkip     { -1pt }             % 本科小节标题后距
} {
  \cs_new:Npn \nwpuChapterBeforeSkip   { -4pt }              % 研究生章标题前距
  \cs_new:Npn \nwpuChapterAfterSkip    { 14pt }             % 研究生章标题后距
  \cs_new:Npn \nwpuSectionBeforeSkip   { 7pt }              % 研究生节标题前距
  \cs_new:Npn \nwpuSectionAfterSkip    { 0pt }              % 研究生节标题后距
  \cs_new:Npn \nwpuSubsecBeforeSkip    { 6.5pt }            % 研究生小节标题前距
  \cs_new:Npn \nwpuSubsecAfterSkip     { 0pt }              % 研究生小节标题后距
}

%%=== 浮动体间距 =========================================================
\nwpu_if_bachelor:TF {
  \cs_new:Npn \nwpuFloatSep     { 20pt }                    % 本科浮动体之间距离
  \cs_new:Npn \nwpuTextFloatSep { 20pt }                    % 本科浮动体与正文距离
  \cs_new:Npn \nwpuInTextSep    { 20pt }                    % 本科文中浮动体上下距离
} {
  \cs_new:Npn \nwpuFloatSep     { 8pt }                     % 研究生浮动体之间距离
  \cs_new:Npn \nwpuTextFloatSep { 8pt }                     % 研究生浮动体与正文距离
  \cs_new:Npn \nwpuInTextSep    { 8pt }                     % 研究生文中浮动体上下距离
}

%%=== 表格线宽 ===========================================================
\cs_new:Npn \nwpuHeavyRuleWidth { 1.5pt }                   % booktabs 粗线宽度
\cs_new:Npn \nwpuLightRuleWidth { 1.0pt }                   % booktabs 细线宽度

%%=== 表格格式 ===========================================================
\cs_new:Npn \nwpuGraduateTableLineHeight { 11.5pt }          % 研究生表格内容行距
\cs_new:Npn \nwpuGraduateTableLineSpread { 1 }              % 研究生表格内部行距倍率
\cs_new:Npn \nwpuTableArrayStretch { 1.4 }                  % 全局表格行高倍率
\cs_new:Npn \nwpuTableRuleWidth { 0.5pt }                   % 全局普通表格线宽
\cs_new:Npn \nwpuTableColumnSep { 0pt }                     % 全局表格列内左右边距

%%=== 封皮与内封尺寸 =====================================================
\cs_new:Npn \nwpuCoverVisualBottomRaise { 1.5pt }           % 封皮固定高度单元格文字底端微调
\cs_new:Npn \nwpuCoverDetailLabelWidth { 2.05cm }           % 封皮右上角信息表标签列宽
\cs_new:Npn \nwpuCoverDetailValueWidth { 2.4cm }            % 封皮右上角信息表内容列宽
\cs_new:Npn \nwpuCoverDetailLabelTextWidth { 4em }          % 封皮右上角信息表标签字距拉伸宽度
\cs_new:Npn \nwpuCoverTitleLabelWidth { 2.34cm }            % 封皮题目表标签列宽

\cs_new:Npn \nwpuChsInnerInfoValueMinWidth { 4.34cm }       % 中文内封作者信息表内容列最小宽度
\cs_new:Npn \nwpuChsInnerInfoRowHeight { 1cm }              % 中文内封作者信息表单元格高度
\cs_new:Npn \nwpuChsInnerLineSpread { 1.4 }                 % 中文内封整体行距倍率
\cs_new:Npn \nwpuChsInnerSchoolTitleStretch { 1.41667 }     % 中文内封校名/文档类型标题拉伸倍率
\cs_new:Npn \nwpuChsInnerTopSkip { 32pt }                 % 中文内封顶部空白
\cs_new:Npn \nwpuChsInnerAfterSchoolSkip { 4mm }            % 中文内封校名后距
\cs_new:Npn \nwpuChsInnerBeforeTitleSkip { 170pt }        % 中文内封题目表前距
\cs_new:Npn \nwpuChsInnerAfterTitleSkip { 100pt }          % 中文内封题目表后距
\cs_new:Npn \nwpuChsInnerAfterInfoSkip { 35pt }           % 中文内封作者信息表后距

